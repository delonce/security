<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-insert-default-roles" author="system">
        <insert tableName="roles">
            <column name="name" value="USER"/>
            <column name="description" value="Regular user role"/>
        </insert>
        <insert tableName="roles">
            <column name="name" value="ADMIN"/>
            <column name="description" value="Administrator role"/>
        </insert>
        <insert tableName="roles">
            <column name="name" value="MODERATOR"/>
            <column name="description" value="Moderator role"/>
        </insert>
    </changeSet>

</databaseChangeLog>
